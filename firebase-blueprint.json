{
  "entities": {
    "Reservation": {
      "title": "Reservation",
      "description": "A breakfast reservation at Nationalpark Café Wistlberg",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "The date of the reservation" },
        "time": { "type": "string", "description": "The time slot for breakfast" },
        "guests": { "type": "number", "description": "Number of people" },
        "name": { "type": "string", "description": "Customer name" },
        "email": { "type": "string", "format": "email", "description": "Customer email" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Reservation status" },
        "notes": { "type": "string", "description": "Special requests or notes" },
        "userId": { "type": "string", "description": "The UID of the user who made the reservation" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the reservation was created" }
      },
      "required": ["date", "time", "guests", "name", "email", "status", "userId", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the reservation system",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "role": { "type": "string", "enum": ["customer", "admin"], "description": "User's role" }
      },
      "required": ["uid", "name", "email", "role"]
    }
  },
  "firestore": {
    "/reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Collection of all breakfast reservations"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles and roles"
    }
  }
}
